# --- MAIN DISPLAY LOOP ---
while not stream.stopped:
    display_img = stream.read()
    if display_img is None:
        time.sleep(0.01)
        continue

    h, w, _ = display_img.shape
    left_boundary = w // 3
    right_boundary = (2 * w) // 3

    with lock:
        boxes_to_draw = list(active_boxes)
        status_text = str(ai_status_msg)

    # Render bounding boxes
    for x1, y1, x2, y2, color, label in boxes_to_draw:
        cv2.rectangle(display_img, (x1, y1), (x2, y2), color, 2)
        cv2.putText(
            display_img,
            label,
            (x1, max(y1 - 10, 20)),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.5,
            color,
            2,
        )

    # Render division lines
    cv2.line(
        display_img, (left_boundary, 0), (left_boundary, h), (200, 200, 200), 2
    )
    cv2.line(
        display_img,
        (right_boundary, 0),
        (right_boundary, h),
        (200, 200, 200),
        2,
    )

    # Display AI diagnostic status bar directly on top of the image
    cv2.putText(
        display_img,
        status_text,
        (10, 30),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.7,
        (0, 255, 255),
        2,
    )

    aspect_ratio = h / w
    display_height = int(STREAM_WIDTH * aspect_ratio)
    resized_display = cv2.resize(display_img, (STREAM_WIDTH, display_height))

    with frame_lock:
        output_frame = resized_display.copy()

    cv2.imshow("ARUS 2026 - Pi Vision", resized_display)

    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

stream.stop()
