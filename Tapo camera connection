# --- AI INFERENCE SETUP ---
print("Loading YOLO model...")
model = YOLO("yolo11n.pt")

active_boxes = []
lock = threading.Lock()
last_msg_time = 0
msg_interval = 0.5


def ai_worker(stream_obj):
    global active_boxes, last_msg_time, ai_status_msg

    print("🚀 AI Worker Thread Active!")

    while not stream_obj.stopped:
        try:
            img = stream_obj.read()
            if img is None:
                time.sleep(0.01)
                continue

            h, w, _ = img.shape
            left_boundary = w // 3
            right_boundary = (2 * w) // 3

            # Run YOLO Detection with lower confidence threshold
            results = model(
                img, imgsz=640, verbose=False, device="cpu", conf=0.30
            )

            temp_boxes = []
            trash_found_in_frame = False
            detected_count = 0

            for r in results:
                if r.boxes is None or len(r.boxes) == 0:
                    continue

                for box in r.boxes:
                    class_id = int(box.cls[0].item())

                    # Safe Box Extraction
                    x1, y1, x2, y2 = (
                        box.xyxy[0].cpu().numpy().astype(int).tolist()
                    )
                    item_name = model.names[class_id]
                    obj_center_x = (x1 + x2) // 2

                    # Zone calculation
                    if obj_center_x < left_boundary:
                        zone, color = "LEFT", (255, 100, 0)
                    elif obj_center_x > right_boundary:
                        zone, color = "RIGHT", (0, 0, 255)
                    else:
                        zone, color = "CENTER", (0, 255, 0)

                    label_type = (
                        "TRASH" if class_id in TRASH_IDS else "PERSON/OBJ"
                    )
                    temp_boxes.append(
                        (
                            x1,
                            y1,
                            x2,
                            y2,
                            color,
                            f"{label_type}: {item_name} ({class_id})",
                        )
                    )
                    detected_count += 1

                    # Publish MQTT payload for Trash Items
                    current_time = time.time()
                    if class_id in TRASH_IDS:
                        trash_found_in_frame = True
                        if (current_time - last_msg_time) >= msg_interval:
                            payload = json.dumps({"i": item_name, "z": zone})
                            if mqtt_connected:
                                client.publish(MQTT_TOPIC, payload)
                            last_msg_time = current_time
                            print(f"⏱️ MQTT Sent: {payload}")

            # Send STOP message if no trash present
            current_time = time.time()
            if (
                not trash_found_in_frame
                and (current_time - last_msg_time) >= msg_interval
            ):
                payload = json.dumps({"i": "none", "z": "STOP"})
                if mqtt_connected:
                    client.publish(MQTT_TOPIC, payload)
                last_msg_time = current_time

            # Update bounding boxes thread-safely
            with lock:
                active_boxes = temp_boxes
                ai_status_msg = f"AI Running - Detected: {detected_count} objs"

            time.sleep(0.01)

        except Exception as e:
            ai_status_msg = f"AI Error: {e}"
            print(f"❌ AI Worker Error: {e}")
            traceback.print_exc()
            time.sleep(0.5)


