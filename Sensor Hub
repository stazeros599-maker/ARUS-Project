// ======================================================
// ESP32 ENVIRONMENT MONITOR
// LM35 + Voltage Sensor + SHT40 RS485
// LCD I2C + WiFi + MQTT + Arduino OTA
// ======================================================

#include <Arduino.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>

// ======================================================
// PIN DEFINITIONS
// ======================================================

#define LM35_PIN       34
#define VOLTAGE_PIN    35

#define SDA_PIN        21
#define SCL_PIN        19

// ESP32 RX receives from converter TXD
#define RS485_RX       26

// ESP32 TX sends to converter RXD
#define RS485_TX       27

// ======================================================
// OBJECTS
// ======================================================

HardwareSerial RS485(2);

LiquidCrystal_I2C lcd(0x27, 20, 4);

WiFiClient espClient;
PubSubClient client(espClient);

// ======================================================
// NETWORK CONFIGURATION
// ======================================================

const char* ssid = "TOTOLINK-71ED";
const char* password = "12345678";

const char* mqtt_server = "192.168.0.197";
const uint16_t mqtt_port = 1883;

// ======================================================
// SENSOR VARIABLES
// ======================================================

float environmentTemp = 0.0;
float environmentHumidity = 0.0;

float boxTemp = 0.0;
float batteryVoltage = 0.0;

bool sht40Connected = false;
bool otaStarted = false;

String currentDirection = "STOP";

// Ubah nilai ini mengikut voltage divider sebenar
const float DIVIDER_RATIO = 5.0;

// ======================================================
// SHT40 MODBUS COMMAND
// Slave ID 1
// Function code 04
// Start register 0001
// Read 2 registers
// ======================================================

const uint8_t requestData[] = {
  0x01, 0x04, 0x00, 0x01,
  0x00, 0x02, 0x20, 0x0B
};

// ======================================================
// MODBUS CRC
// ======================================================

uint16_t calculateModbusCRC(
  const uint8_t* data,
  uint8_t length
) {
  uint16_t crc = 0xFFFF;

  for (uint8_t i = 0; i < length; i++) {
    crc ^= data[i];

    for (uint8_t bit = 0; bit < 8; bit++) {
      if (crc & 0x0001) {
        crc >>= 1;
        crc ^= 0xA001;
      } else {
        crc >>= 1;
      }
    }
  }

  return crc;
}

// ======================================================
// PRINT HEX BYTE
// ======================================================

void printHexByte(uint8_t value) {
  if (value < 0x10) {
    Serial.print("0");
  }

  Serial.print(value, HEX);
}

// ======================================================
// MQTT CALLBACK
// ======================================================

void callback(
  char* topic,
  byte* payload,
  unsigned int length
) {
  String message = "";

  for (unsigned int i = 0; i < length; i++) {
    message += (char)payload[i];
  }

  message.trim();

  Serial.print("MQTT received [");
  Serial.print(topic);
  Serial.print("]: ");
  Serial.println(message);

  if (String(topic) == "home/getDirection") {
    currentDirection = message;
  }
}

// ======================================================
// MQTT CONNECTION
// ======================================================

bool reconnectMQTT() {
  if (client.connected()) {
    return true;
  }

  if (WiFi.status() != WL_CONNECTED) {
    return false;
  }

  String clientId = "ESP32-Environment-";
  clientId += String(
    (uint64_t)ESP.getEfuseMac(),
    HEX
  );

  Serial.print("Connecting MQTT... ");

  if (client.connect(clientId.c_str())) {
    Serial.println("CONNECTED");

    client.subscribe("home/getDirection");

    return true;
  }

  Serial.print("FAILED, state=");
  Serial.println(client.state());

  return false;
}

// ======================================================
// WIFI CONNECTION
// ======================================================

void connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    return;
  }

  Serial.print("Connecting WiFi");

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting WiFi...");

  unsigned long startTime = millis();

  while (
    WiFi.status() != WL_CONNECTED &&
    millis() - startTime < 10000
  ) {
    Serial.print(".");
    delay(300);
  }

  Serial.println();

  lcd.clear();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("WiFi CONNECTED");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());

    lcd.setCursor(0, 0);
    lcd.print("WiFi Connected");

    lcd.setCursor(0, 1);
    lcd.print(WiFi.localIP());
  } else {
    Serial.println("WiFi FAILED");

    lcd.setCursor(0, 0);
    lcd.print("WiFi Failed");
  }

  delay(1500);
}

// ======================================================
// OTA SETUP
// ======================================================

void setupOTA() {
  if (otaStarted) {
    return;
  }

  if (WiFi.status() != WL_CONNECTED) {
    return;
  }

  ArduinoOTA.setHostname(
    "ESP32-Environment-Node"
  );

  ArduinoOTA.setPassword("12345678");

  ArduinoOTA.onStart([]() {
    Serial.println("OTA upload starting");

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Upload");

    lcd.setCursor(0, 1);
    lcd.print("Starting...");
  });

  ArduinoOTA.onProgress([](
    unsigned int progress,
    unsigned int total
  ) {
    unsigned int percent =
      (progress * 100U) / total;

    lcd.setCursor(0, 0);
    lcd.print("OTA Progress        ");

    lcd.setCursor(0, 1);
    lcd.print(percent);
    lcd.print("%                  ");
  });

  ArduinoOTA.onEnd([]() {
    Serial.println("OTA upload completed");

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Completed");

    lcd.setCursor(0, 1);
    lcd.print("Restarting...");
  });

  ArduinoOTA.onError([](ota_error_t error) {
    Serial.print("OTA error: ");
    Serial.println(error);

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Error");

    lcd.setCursor(0, 1);
    lcd.print("Code: ");
    lcd.print(error);
  });

  ArduinoOTA.begin();
  otaStarted = true;

  Serial.println("Arduino OTA READY");
}

// ======================================================
// READ SHT40 RS485
// ======================================================

bool readSHT40() {
  while (RS485.available()) {
    RS485.read();
  }

  // Beri laluan RS485 masa untuk senyap
  delay(100);

  Serial.println();
  Serial.println("SHT40 RS485 REQUEST");
  Serial.println("TX: 01 04 00 01 00 02 20 0B");

  size_t sent = RS485.write(
    requestData,
    sizeof(requestData)
  );

  RS485.flush();

  Serial.print("Bytes sent: ");
  Serial.println(sent);

  uint8_t response[32];
  int count = 0;

  unsigned long startTime = millis();
  unsigned long lastByteTime = 0;

  while (millis() - startTime < 2000) {
    if (RS485.available()) {
      while (
        RS485.available() &&
        count < sizeof(response)
      ) {
        response[count++] = RS485.read();
        lastByteTime = millis();
      }
    }

    if (
      count > 0 &&
      millis() - lastByteTime >= 50
    ) {
      break;
    }

    delay(1);
  }

  Serial.print("RX bytes: ");
  Serial.println(count);

  if (count > 0) {
    Serial.print("RX: ");

    for (int i = 0; i < count; i++) {
      if (response[i] < 0x10) {
        Serial.print("0");
      }

      Serial.print(response[i], HEX);
      Serial.print(" ");
    }

    Serial.println();
  }

  if (count != 9) {
    Serial.println("SHT40: TIADA RESPONSE MODBUS SAH");
    sht40Connected = false;
    return false;
  }

  if (
    response[0] != 0x01 ||
    response[1] != 0x04 ||
    response[2] != 0x04
  ) {
    Serial.println("SHT40: FORMAT RESPONSE SALAH");
    sht40Connected = false;
    return false;
  }

  uint16_t calculatedCRC =
    calculateModbusCRC(response, 7);

  uint16_t receivedCRC =
    response[7] |
    ((uint16_t)response[8] << 8);

  if (calculatedCRC != receivedCRC) {
    Serial.println("SHT40: CRC SALAH");
    sht40Connected = false;
    return false;
  }

  int16_t tempRaw =
    ((int16_t)response[3] << 8) |
    response[4];

  uint16_t humidityRaw =
    ((uint16_t)response[5] << 8) |
    response[6];

  environmentTemp = tempRaw / 10.0;
  environmentHumidity = humidityRaw / 10.0;

  sht40Connected = true;

  Serial.print("Temperature: ");
  Serial.print(environmentTemp, 2);
  Serial.println(" C");

  Serial.print("Humidity: ");
  Serial.print(environmentHumidity, 2);
  Serial.println(" %RH");

  return true;
}

// ======================================================
// READ LM35
// ======================================================

float readBoxTemperature() {
  uint32_t totalMillivolts = 0;

  const int samples = 50;

  for (int i = 0; i < samples; i++) {
    totalMillivolts +=
      analogReadMilliVolts(LM35_PIN);

    delay(2);
  }

  float averageMillivolts =
    totalMillivolts / (float)samples;

  // LM35 = 10 mV per degree Celsius
  return averageMillivolts / 10.0;
}

// ======================================================
// READ VOLTAGE SENSOR
// ======================================================

float readVoltage() {
  uint32_t totalMillivolts = 0;

  const int samples = 50;

  for (int i = 0; i < samples; i++) {
    totalMillivolts +=
      analogReadMilliVolts(VOLTAGE_PIN);

    delay(2);
  }

  float averageMillivolts =
    totalMillivolts / (float)samples;

  return
    (averageMillivolts / 1000.0) *
    DIVIDER_RATIO;
}

// ======================================================
// MQTT PUBLISH
// ======================================================

void publishSensorData() {
  if (!client.connected()) {
    return;
  }

  char value[20];

  dtostrf(
    batteryVoltage,
    1,
    2,
    value
  );

  client.publish(
    "home/voltage",
    value
  );

  dtostrf(
    boxTemp,
    1,
    2,
    value
  );

  client.publish(
    "home/boxTemp",
    value
  );

  if (sht40Connected) {
    dtostrf(
      environmentTemp,
      1,
      2,
      value
    );

    client.publish(
      "home/envTemp",
      value
    );

    dtostrf(
      environmentHumidity,
      1,
      2,
      value
    );

    client.publish(
      "home/envHum",
      value
    );
  }
}

// ======================================================
// SERIAL MONITOR OUTPUT
// ======================================================

void printSystemOutput() {
  Serial.println();
  Serial.println(
    "========================================"
  );

  Serial.println(
    "        ENVIRONMENT MONITOR"
  );

  Serial.println(
    "========================================"
  );

  Serial.print("Box Temperature : ");
  Serial.print(boxTemp, 1);
  Serial.println(" C");

  Serial.print("Battery Voltage : ");
  Serial.print(batteryVoltage, 2);
  Serial.println(" V");

  if (sht40Connected) {
    Serial.print("Environment Temp: ");
    Serial.print(environmentTemp, 1);
    Serial.println(" C");

    Serial.print("Humidity        : ");
    Serial.print(environmentHumidity, 1);
    Serial.println(" %RH");
  } else {
    Serial.println(
      "Environment Temp: --"
    );

    Serial.println(
      "Humidity        : --"
    );
  }

  Serial.print("Direction       : ");
  Serial.println(currentDirection);

  Serial.print("SHT40 Status    : ");

  if (sht40Connected) {
    Serial.println("CONNECTED");
  } else {
    Serial.println("NO RESPONSE");
  }

  Serial.print("WiFi            : ");

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("CONNECTED");
  } else {
    Serial.println("DISCONNECTED");
  }

  Serial.print("MQTT            : ");

  if (client.connected()) {
    Serial.println("CONNECTED");
  } else {
    Serial.println("DISCONNECTED");
  }

  Serial.println(
    "========================================"
  );
}

// ======================================================
// LCD DISPLAY
// ======================================================

void updateLCD() {
  // Line 1: Box temperature
  lcd.setCursor(0, 0);
  lcd.print("Box:");
  lcd.print(boxTemp, 1);
  lcd.print((char)223);
  lcd.print("C");
  lcd.print("            ");

  // Line 2: Voltage
  lcd.setCursor(0, 1);
  lcd.print("Volt:");
  lcd.print(batteryVoltage, 2);
  lcd.print("V");
  lcd.print("           ");

  // Line 3: Environment
  lcd.setCursor(0, 2);

  if (sht40Connected) {
    lcd.print("Env:");
    lcd.print(environmentTemp, 1);
    lcd.print((char)223);
    lcd.print("C ");

    lcd.print(environmentHumidity, 1);
    lcd.print("%");
  } else {
    lcd.print("SHT40: NO RESPONSE");
  }

  lcd.print("                    ");

  // Line 4: Direction
  lcd.setCursor(0, 3);
  lcd.print("Dir:");
  lcd.print(currentDirection);
  lcd.print("                ");
}

// ======================================================
// SETUP
// ======================================================

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("ESP32 ENVIRONMENT MONITOR STARTING");

  // Mulakan RS485 dahulu
  RS485.setRxBufferSize(256);

  RS485.begin(
    9600,
    SERIAL_8N1,
    RS485_RX,
    RS485_TX
  );

  delay(1000);

  Serial.println("RS485 SHT40 READY");

  // Uji sensor sebelum LCD, WiFi, MQTT dan OTA
  Serial.println("INITIAL SHT40 TEST BEFORE WIFI");
  readSHT40();

  delay(1000);

  // Selepas sensor diuji, baru mulakan LCD
  Wire.begin(SDA_PIN, SCL_PIN);

  lcd.init();
  lcd.backlight();
  lcd.clear();

  lcd.setCursor(0, 0);
  lcd.print("System Starting...");

  analogReadResolution(12);

  analogSetPinAttenuation(
    LM35_PIN,
    ADC_11db
  );

  analogSetPinAttenuation(
    VOLTAGE_PIN,
    ADC_11db
  );

  // Baru hidupkan WiFi
  connectWiFi();

  if (WiFi.status() == WL_CONNECTED) {
    setupOTA();
  }

  client.setServer(
    mqtt_server,
    mqtt_port
  );

  client.setCallback(callback);

  lcd.clear();
}

// ======================================================
// LOOP
// ======================================================

void loop() {
  // Jalankan OTA hanya apabila sudah dimulakan
  if (
    otaStarted &&
    WiFi.status() == WL_CONNECTED
  ) {
    ArduinoOTA.handle();
  }

  // WiFi reconnect setiap 10 saat
  static unsigned long lastWiFiCheck = 0;

  if (
    millis() - lastWiFiCheck >= 10000
  ) {
    lastWiFiCheck = millis();

    if (WiFi.status() != WL_CONNECTED) {
      connectWiFi();
    }

    if (
      WiFi.status() == WL_CONNECTED &&
      !otaStarted
    ) {
      setupOTA();
    }
  }

  // MQTT reconnect setiap 5 saat
  static unsigned long lastMQTTAttempt = 0;

  if (!client.connected()) {
    if (
      WiFi.status() == WL_CONNECTED &&
      millis() - lastMQTTAttempt >= 5000
    ) {
      lastMQTTAttempt = millis();
      reconnectMQTT();
    }
  } else {
    client.loop();
  }

  // Baca sensor setiap 2 saat
  static unsigned long lastSensorRead = 0;

  if (
    millis() - lastSensorRead >= 2000
  ) {
    lastSensorRead = millis();

    boxTemp = readBoxTemperature();
    batteryVoltage = readVoltage();

    readSHT40();

    publishSensorData();
    updateLCD();
    printSystemOutput();
  }

  delay(5);
}
