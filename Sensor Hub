// ======================================================
// ESP32 ENVIRONMENT + UNDERWATER DISTANCE MONITOR
// LM35 + Voltage Sensor + SHT40 RS485 + DFRobot SEN0598
// LCD I2C + WiFi + MQTT + Arduino OTA
// ======================================================

#include <Arduino.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>

// ======================================================
// PIN DEFINITIONS
// ======================================================

#define LM35_PIN          34
#define VOLTAGE_PIN       35

#define SDA_PIN           21
#define SCL_PIN           19

// SHT40 through TTL-to-RS485 converter (UART2)
#define RS485_RX          26   // Converter TXD -> ESP32 GPIO26
#define RS485_TX          27   // Converter RXD -> ESP32 GPIO27

// DFRobot SEN0598 direct UART (UART1)
#define ULTRASONIC_RX     16   // Sensor white TX -> ESP32 GPIO16
#define ULTRASONIC_TX     17   // Sensor yellow RX -> ESP32 GPIO17

// ======================================================
// SERIAL OBJECTS
// IMPORTANT: Do not use Serial2 for both sensors.
// ======================================================

HardwareSerial RS485(2);       // UART2 for SHT40
HardwareSerial Ultrasonic(1);  // UART1 for SEN0598

LiquidCrystal_I2C lcd(0x27, 20, 4);

WiFiClient espClient;
PubSubClient client(espClient);

// ======================================================
// NETWORK CONFIGURATION
// ======================================================

const char* ssid = "TOTOLINK-71ED";
const char* password = "12345678";

const char* mqtt_server = "192.168.0.197";
const uint16_t mqtt_port = 1883;

// ======================================================
// SENSOR VARIABLES
// ======================================================

float environmentTemp = 0.0;
float environmentHumidity = 0.0;
float boxTemp = 0.0;
float batteryVoltage = 0.0;

uint16_t distanceMm = 0;
float distanceCm = 0.0;

bool sht40Connected = false;
bool ultrasonicConnected = false;
bool otaStarted = false;

String currentDirection = "STOP";

const float DIVIDER_RATIO = 5.0;

// ======================================================
// SENSOR COMMANDS
// ======================================================

// SHT40: ID 1, FC04, register 0001, read 2 registers
const uint8_t sht40Request[] = {
  0x01, 0x04, 0x00, 0x01,
  0x00, 0x02, 0x20, 0x0B
};

// SEN0598 trigger command
const uint8_t ULTRASONIC_TRIGGER = 0x55;

// ======================================================
// MODBUS CRC
// ======================================================

uint16_t calculateModbusCRC(const uint8_t* data, uint8_t length) {
  uint16_t crc = 0xFFFF;

  for (uint8_t i = 0; i < length; i++) {
    crc ^= data[i];

    for (uint8_t bit = 0; bit < 8; bit++) {
      if (crc & 0x0001) {
        crc >>= 1;
        crc ^= 0xA001;
      } else {
        crc >>= 1;
      }
    }
  }

  return crc;
}

void printHexByte(uint8_t value) {
  if (value < 0x10) {
    Serial.print("0");
  }
  Serial.print(value, HEX);
}

// ======================================================
// MQTT CALLBACK
// ======================================================

void callback(char* topic, byte* payload, unsigned int length) {
  String message;

  for (unsigned int i = 0; i < length; i++) {
    message += (char)payload[i];
  }

  message.trim();

  Serial.print("MQTT received [");
  Serial.print(topic);
  Serial.print("]: ");
  Serial.println(message);

  if (String(topic) == "home/getDirection") {
    currentDirection = message;
  }
}

// ======================================================
// MQTT
// ======================================================

bool reconnectMQTT() {
  if (client.connected()) {
    return true;
  }

  if (WiFi.status() != WL_CONNECTED) {
    return false;
  }

  String clientId = "ESP32-Environment-";
  clientId += String((uint64_t)ESP.getEfuseMac(), HEX);

  Serial.print("Connecting MQTT... ");

  if (client.connect(clientId.c_str())) {
    Serial.println("CONNECTED");
    client.subscribe("home/getDirection");
    return true;
  }

  Serial.print("FAILED, state=");
  Serial.println(client.state());
  return false;
}

// ======================================================
// WIFI
// ======================================================

void connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    return;
  }

  Serial.print("Connecting WiFi");

  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.begin(ssid, password);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting WiFi...");

  unsigned long startTime = millis();

  while (
    WiFi.status() != WL_CONNECTED &&
    millis() - startTime < 10000
  ) {
    Serial.print(".");
    delay(300);
  }

  Serial.println();
  lcd.clear();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("WiFi CONNECTED");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());

    lcd.setCursor(0, 0);
    lcd.print("WiFi Connected");
    lcd.setCursor(0, 1);
    lcd.print(WiFi.localIP());
  } else {
    Serial.println("WiFi FAILED");
    lcd.setCursor(0, 0);
    lcd.print("WiFi Failed");
  }

  delay(1500);
}

// ======================================================
// OTA
// ======================================================

void setupOTA() {
  if (otaStarted || WiFi.status() != WL_CONNECTED) {
    return;
  }

  ArduinoOTA.setHostname("ESP32-Environment-Node");
  ArduinoOTA.setPassword("12345678");

  ArduinoOTA.onStart([]() {
    Serial.println("OTA upload starting");
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Upload");
    lcd.setCursor(0, 1);
    lcd.print("Starting...");
  });

  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    unsigned int percent = (progress * 100U) / total;

    lcd.setCursor(0, 0);
    lcd.print("OTA Progress        ");
    lcd.setCursor(0, 1);
    lcd.print(percent);
    lcd.print("%                  ");
  });

  ArduinoOTA.onEnd([]() {
    Serial.println("OTA upload completed");
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Completed");
    lcd.setCursor(0, 1);
    lcd.print("Restarting...");
  });

  ArduinoOTA.onError([](ota_error_t error) {
    Serial.print("OTA error: ");
    Serial.println(error);

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("OTA Error");
    lcd.setCursor(0, 1);
    lcd.print("Code: ");
    lcd.print(error);
  });

  ArduinoOTA.begin();
  otaStarted = true;
  Serial.println("Arduino OTA READY");
}

// ======================================================
// READ SHT40 RS485
// ======================================================

bool readSHT40() {
  while (RS485.available()) {
    RS485.read();
  }

  delay(20);

  Serial.println();
  Serial.println("SHT40 RS485 REQUEST");
  Serial.print("TX: ");

  for (uint8_t i = 0; i < sizeof(sht40Request); i++) {
    printHexByte(sht40Request[i]);
    Serial.print(" ");
  }
  Serial.println();

  RS485.write(sht40Request, sizeof(sht40Request));
  RS485.flush();

  uint8_t response[32];
  int count = 0;

  unsigned long startTime = millis();
  unsigned long lastByteTime = 0;

  while (millis() - startTime < 1500) {
    while (RS485.available() && count < (int)sizeof(response)) {
      response[count++] = RS485.read();
      lastByteTime = millis();
    }

    if (count > 0 && millis() - lastByteTime > 30) {
      break;
    }

    delay(1);
  }

  Serial.print("RX bytes: ");
  Serial.println(count);

  if (count > 0) {
    Serial.print("RX: ");

    for (int i = 0; i < count; i++) {
      printHexByte(response[i]);
      Serial.print(" ");
    }
    Serial.println();
  }

  if (count != 9) {
    Serial.println("SHT40: TIADA RESPONSE MODBUS SAH");
    sht40Connected = false;
    return false;
  }

  if (
    response[0] != 0x01 ||
    response[1] != 0x04 ||
    response[2] != 0x04
  ) {
    Serial.println("SHT40: FORMAT RESPONSE SALAH");
    sht40Connected = false;
    return false;
  }

  uint16_t calculatedCRC = calculateModbusCRC(response, 7);
  uint16_t receivedCRC =
    response[7] | ((uint16_t)response[8] << 8);

  if (calculatedCRC != receivedCRC) {
    Serial.println("SHT40: CRC SALAH");
    sht40Connected = false;
    return false;
  }

  int16_t tempRaw =
    ((int16_t)response[3] << 8) | response[4];

  uint16_t humidityRaw =
    ((uint16_t)response[5] << 8) | response[6];

  float newTemp = tempRaw / 10.0;
  float newHumidity = humidityRaw / 10.0;

  if (
    newTemp < -40.0 ||
    newTemp > 120.0 ||
    newHumidity > 100.0
  ) {
    Serial.println("SHT40: BACAAN DI LUAR JULAT");
    sht40Connected = false;
    return false;
  }

  environmentTemp = newTemp;
  environmentHumidity = newHumidity;
  sht40Connected = true;

  Serial.print("Temperature: ");
  Serial.print(environmentTemp, 2);
  Serial.println(" C");

  Serial.print("Humidity   : ");
  Serial.print(environmentHumidity, 2);
  Serial.println(" %RH");

  return true;
}

// ======================================================
// READ DFRobot SEN0598
// UART1: RX GPIO16, TX GPIO17
// ======================================================

bool readUltrasonic() {
  while (Ultrasonic.available()) {
    Ultrasonic.read();
  }

  Ultrasonic.write(ULTRASONIC_TRIGGER);
  Ultrasonic.flush();

  // Datasheet timing: wait at least about 19 ms
  delay(30);

  uint8_t response[4] = {0};
  int byteCount = 0;
  unsigned long startTime = millis();

  while (
    millis() - startTime < 150 &&
    byteCount < 4
  ) {
    while (
      Ultrasonic.available() &&
      byteCount < 4
    ) {
      response[byteCount++] = Ultrasonic.read();
    }

    delay(1);
  }

  Serial.println();
  Serial.println("SEN0598 UART REQUEST");
  Serial.print("TX: 55");
  Serial.println();

  Serial.print("RX bytes: ");
  Serial.print(byteCount);
  Serial.print(" | ");

  for (int i = 0; i < byteCount; i++) {
    printHexByte(response[i]);
    Serial.print(" ");
  }
  Serial.println();

  if (byteCount != 4) {
    Serial.println("SEN0598: RESPONSE TIDAK LENGKAP");
    ultrasonicConnected = false;
    return false;
  }

  if (response[0] != 0xFF) {
    Serial.println("SEN0598: HEADER SALAH");
    ultrasonicConnected = false;
    return false;
  }

  uint8_t calculatedChecksum =
    (response[0] + response[1] + response[2]) & 0xFF;

  if (calculatedChecksum != response[3]) {
    Serial.print("SEN0598: CHECKSUM SALAH. Expected: ");
    printHexByte(calculatedChecksum);
    Serial.println();

    ultrasonicConnected = false;
    return false;
  }

  distanceMm =
    ((uint16_t)response[1] << 8) | response[2];

  distanceCm = distanceMm / 10.0;
  ultrasonicConnected = true;

  Serial.print("Depth: ");
  Serial.print(distanceMm);
  Serial.println(" mm");

  Serial.print("Depth: ");
  Serial.print(distanceCm, 1);
  Serial.println(" cm");

  if (distanceMm == 0) {
    Serial.println(
      "SEN0598: Tiada echo sah atau sensor belum berada dalam air."
    );
  }

  return true;
}

// ======================================================
// READ LM35
// ======================================================

float readBoxTemperature() {
  uint32_t totalMillivolts = 0;
  const int samples = 50;

  for (int i = 0; i < samples; i++) {
    totalMillivolts += analogReadMilliVolts(LM35_PIN);
    delay(2);
  }

  float averageMillivolts =
    totalMillivolts / (float)samples;

  return averageMillivolts / 10.0;
}

// ======================================================
// READ VOLTAGE SENSOR
// ======================================================

float readVoltage() {
  uint32_t totalMillivolts = 0;
  const int samples = 50;

  for (int i = 0; i < samples; i++) {
    totalMillivolts += analogReadMilliVolts(VOLTAGE_PIN);
    delay(2);
  }

  float averageMillivolts =
    totalMillivolts / (float)samples;

  return
    (averageMillivolts / 1000.0) *
    DIVIDER_RATIO;
}

// ======================================================
// MQTT PUBLISH
// ======================================================

void publishSensorData() {
  if (!client.connected()) {
    return;
  }

  char value[20];

  dtostrf(batteryVoltage, 1, 2, value);
  client.publish("home/voltage", value);

  dtostrf(boxTemp, 1, 2, value);
  client.publish("home/boxTemp", value);

  if (sht40Connected) {
    dtostrf(environmentTemp, 1, 2, value);
    client.publish("home/envTemp", value);

    dtostrf(environmentHumidity, 1, 2, value);
    client.publish("home/envHum", value);
  }

  if (ultrasonicConnected) {
    snprintf(value, sizeof(value), "%u", distanceMm);
    client.publish("home/distanceMm", value);

    dtostrf(distanceCm, 1, 1, value);
    client.publish("home/distanceCm", value);
  }
}

// ======================================================
// SERIAL OUTPUT
// ======================================================

void printSystemOutput() {
  Serial.println();
  Serial.println("========================================");
  Serial.println("       ENVIRONMENT + DEPTH MONITOR");
  Serial.println("========================================");

  Serial.print("Box Temperature : ");
  Serial.print(boxTemp, 1);
  Serial.println(" C");

  Serial.print("Battery Voltage : ");
  Serial.print(batteryVoltage, 2);
  Serial.println(" V");

  if (sht40Connected) {
    Serial.print("Environment Temp: ");
    Serial.print(environmentTemp, 1);
    Serial.println(" C");

    Serial.print("Humidity        : ");
    Serial.print(environmentHumidity, 1);
    Serial.println(" %RH");
  } else {
    Serial.println("Environment Temp: --");
    Serial.println("Humidity        : --");
  }

  if (ultrasonicConnected) {
    Serial.print("Depth           : ");
    Serial.print(distanceMm);
    Serial.print(" mm / ");
    Serial.print(distanceCm, 1);
    Serial.println(" cm");
  } else {
    Serial.println("Depth        : --");
  }

  Serial.print("Direction       : ");
  Serial.println(currentDirection);

  Serial.print("SHT40 Status    : ");
  Serial.println(sht40Connected ? "CONNECTED" : "NO RESPONSE");

  Serial.print("SEN0598 Status  : ");
  Serial.println(ultrasonicConnected ? "CONNECTED" : "NO RESPONSE");

  Serial.print("WiFi            : ");
  Serial.println(
    WiFi.status() == WL_CONNECTED ?
    "CONNECTED" : "DISCONNECTED"
  );

  Serial.print("MQTT            : ");
  Serial.println(
    client.connected() ?
    "CONNECTED" : "DISCONNECTED"
  );

  Serial.println("========================================");
}

// ======================================================
// LCD DISPLAY
// ======================================================

void updateLCD() {
  lcd.setCursor(0, 0);
  lcd.print("Box:");
  lcd.print(boxTemp, 1);
  lcd.print((char)223);
  lcd.print("C");
  lcd.print("            ");

  lcd.setCursor(0, 1);
  lcd.print("Volt:");
  lcd.print(batteryVoltage, 2);
  lcd.print("V");
  lcd.print("           ");

  lcd.setCursor(0, 2);

  if (sht40Connected) {
    lcd.print("Env:");
    lcd.print(environmentTemp, 1);
    lcd.print((char)223);
    lcd.print("C ");
    lcd.print(environmentHumidity, 1);
    lcd.print("%");
  } else {
    lcd.print("SHT40:NO RESPONSE");
  }

  lcd.print("                    ");

  lcd.setCursor(0, 3);

  if (ultrasonicConnected) {
    lcd.print("D:");
    lcd.print(distanceCm, 1);
    lcd.print("cm ");
    lcd.print(currentDirection);
  } else {
    lcd.print("SEN0598:NO RESPONSE");
  }

  lcd.print("                    ");
}

// ======================================================
// SETUP
// ======================================================

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("ESP32 COMBINED MONITOR STARTING");

  // UART2 for SHT40 RS485
  RS485.setRxBufferSize(256);
  RS485.begin(
    9600,
    SERIAL_8N1,
    RS485_RX,
    RS485_TX
  );

  // UART1 for SEN0598
  Ultrasonic.setRxBufferSize(64);
  Ultrasonic.begin(
    115200,
    SERIAL_8N1,
    ULTRASONIC_RX,
    ULTRASONIC_TX
  );

  delay(1000);

  Serial.println("SHT40 UART2 READY: RX26 TX27");
  Serial.println("SEN0598 UART1 READY: RX16 TX17");

  // LCD
  Wire.begin(SDA_PIN, SCL_PIN);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("System Starting...");

  // ADC
  analogReadResolution(12);
  analogSetPinAttenuation(LM35_PIN, ADC_11db);
  analogSetPinAttenuation(VOLTAGE_PIN, ADC_11db);

  // Initial sensor tests before WiFi
  Serial.println("INITIAL SENSOR TEST BEFORE WIFI");
  readSHT40();
  delay(200);
  readUltrasonic();

  // WiFi + OTA + MQTT
  connectWiFi();

  if (WiFi.status() == WL_CONNECTED) {
    setupOTA();
  }

  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(callback);

  lcd.clear();
}

// ======================================================
// LOOP
// ======================================================

void loop() {
  if (
    otaStarted &&
    WiFi.status() == WL_CONNECTED
  ) {
    ArduinoOTA.handle();
  }

  // WiFi reconnect every 10 seconds
  static unsigned long lastWiFiCheck = 0;

  if (millis() - lastWiFiCheck >= 10000) {
    lastWiFiCheck = millis();

    if (WiFi.status() != WL_CONNECTED) {
      connectWiFi();
    }

    if (
      WiFi.status() == WL_CONNECTED &&
      !otaStarted
    ) {
      setupOTA();
    }
  }

  // MQTT reconnect every 5 seconds
  static unsigned long lastMQTTAttempt = 0;

  if (!client.connected()) {
    if (
      WiFi.status() == WL_CONNECTED &&
      millis() - lastMQTTAttempt >= 5000
    ) {
      lastMQTTAttempt = millis();
      reconnectMQTT();
    }
  } else {
    client.loop();
  }

  // Read all sensors every 2 seconds
  static unsigned long lastSensorRead = 0;

  if (millis() - lastSensorRead >= 2000) {
    lastSensorRead = millis();

    boxTemp = readBoxTemperature();
    batteryVoltage = readVoltage();

    readSHT40();
    delay(100);
    readUltrasonic();

    publishSensorData();
    updateLCD();
    printSystemOutput();
  }

  delay(5);
}
