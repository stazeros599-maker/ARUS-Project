// motor, distance, camera, buzzer
#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoJson.h>

// --- PIN DEFINITIONS ---
#define TRIG_PIN         17
#define ECHO_PIN         16
#define BUZZER_PIN       15

// Original PWM motor pins - DO NOT CHANGE
#define DIR_PIN_A        26 
#define DIR_PIN_B        27 
#define PWM_PIN_A        25 
#define PWM_PIN_B        14 

// --- EXTRA L298N MOTOR DRIVER ---
// This L298N motor runs FORWARD whenever the main PWM motor is moving
#define L298N_ENA_PIN    18
#define L298N_IN1_PIN    19
#define L298N_IN2_PIN    21
#define L298N_IN3_PIN    22
#define L298N_IN4_PIN    23
#define L298N_ENB_PIN    5

// --- PWM CHANNELS ---
#define PWM_A_CH         0
#define PWM_B_CH         1
#define L298N_ENA_CH     2
#define L298N_ENB_CH     3
#define BUZZER_CH        4

// --- GLOBAL VARIABLES ---
bool isAutoMode = false;
float temperature = 0.0;
float humidity = 0.0;

int motorSpeed = 225; 
int l298nSpeed = 225;

// --- NETWORK CONFIG ---
const char* ssid = "TOTOLINK-71ED";
const char* password = "12345678";
const char* mqtt_server = "192.168.0.198";

WiFiClient espClient;
PubSubClient client(espClient);

// --- PWM SETTINGS ---
const int freq = 5000;
const int resolution = 8;

// --- BUZZER FUNCTIONS ---
void playSuccess() {
  ledcWriteTone(BUZZER_CH, 1000); delay(150);
  ledcWriteTone(BUZZER_CH, 1500); delay(150);
  ledcWriteTone(BUZZER_CH, 2000); delay(300);
  ledcWriteTone(BUZZER_CH, 0);    
}

void playMelody() {
  int notes[] = {262, 294, 330, 349, 392, 440, 494, 523};

  for (int i = 0; i < 8; i++) { 
    ledcWriteTone(BUZZER_CH, notes[i]); 
    delay(100); 
  }

  ledcWriteTone(BUZZER_CH, 0);
}

void playWarning() {
  for (int i = 0; i < 3; i++) {
    ledcWriteTone(BUZZER_CH, 1500);
    delay(80);
    ledcWriteTone(BUZZER_CH, 0);
    delay(80);
  }
}

// --- EXTRA L298N MOTOR FUNCTIONS ---
void l298nForward() {
  digitalWrite(L298N_IN1_PIN, HIGH);
  digitalWrite(L298N_IN2_PIN, LOW);

  digitalWrite(L298N_IN3_PIN, HIGH);
  digitalWrite(L298N_IN4_PIN, LOW);

  ledcWrite(L298N_ENA_CH, l298nSpeed);
  ledcWrite(L298N_ENB_CH, l298nSpeed);
}

void l298nStop() {
  ledcWrite(L298N_ENA_CH, 0);
  ledcWrite(L298N_ENB_CH, 0);
}

// --- MAIN PWM MOTOR FUNCTIONS ---
void motorForward() {
  digitalWrite(DIR_PIN_A, LOW);
  digitalWrite(DIR_PIN_B, LOW);

  ledcWrite(PWM_A_CH, motorSpeed);
  ledcWrite(PWM_B_CH, motorSpeed);

  l298nForward();
}

void motorBackward() {
  digitalWrite(DIR_PIN_A, HIGH);
  digitalWrite(DIR_PIN_B, HIGH);

  ledcWrite(PWM_A_CH, motorSpeed);
  ledcWrite(PWM_B_CH, motorSpeed);

  l298nForward();
}

void motorStop() {
  ledcWrite(PWM_A_CH, 0);
  ledcWrite(PWM_B_CH, 0);

  l298nStop();
}

// Sharp 90-degree turns
void motorSharpLeft() {
  digitalWrite(DIR_PIN_A, HIGH);
  digitalWrite(DIR_PIN_B, LOW);

  ledcWrite(PWM_A_CH, motorSpeed);
  ledcWrite(PWM_B_CH, motorSpeed);

  l298nForward();
}

void motorSharpRight() {
  digitalWrite(DIR_PIN_A, LOW);
  digitalWrite(DIR_PIN_B, HIGH);

  ledcWrite(PWM_A_CH, motorSpeed);
  ledcWrite(PWM_B_CH, motorSpeed);

  l298nForward();
}

// Wide turns
void motorLeft() {
  digitalWrite(DIR_PIN_A, LOW);
  digitalWrite(DIR_PIN_B, LOW);

  ledcWrite(PWM_A_CH, 0);
  ledcWrite(PWM_B_CH, motorSpeed);

  l298nForward();
}

void motorRight() {
  digitalWrite(DIR_PIN_A, LOW);
  digitalWrite(DIR_PIN_B, LOW);

  ledcWrite(PWM_A_CH, motorSpeed);
  ledcWrite(PWM_B_CH, 0);

  l298nForward();
}

// --- ULTRASONIC SENSOR ---
long readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  return pulseIn(ECHO_PIN, HIGH, 30000) * 0.034 / 2;
}

// --- MQTT CALLBACK ---
void callback(char* topic, byte* payload, unsigned int length) {
  String topicStr = String(topic);
  
  // --- Handle Mode Switching ---
  if (topicStr == "robot/mode") {
    isAutoMode = (payload[0] - '0' == 1);

    motorStop();

    Serial.println(isAutoMode ? "MODE: AUTO (Camera)" : "MODE: MANUAL (Joystick)");
    return;
  }

  // --- Parse incoming JSON ---
  StaticJsonDocument<200> doc;
  DeserializationError error = deserializeJson(doc, payload, length);

  if (error) {
    Serial.println("MQTT JSON parse failed");
    return;
  }

  // --- Safety Check ---
  long distance = readUltrasonic();
  //long distanceF = distance;
  //long distanceR = distance;
  //long distanceL = distance;

  // --- JOYSTICK TOPIC ---
  if ((topicStr == "robot/direction/joystick" || topicStr == "joystick/data") && !isAutoMode) {
    int x = doc["x"] | 2048;
    int y = doc["y"] | 2048;

    const char* buttonStatus = doc["button"];
    bool buttonPressed = (buttonStatus != NULL && strcmp(buttonStatus, "PRESSED") == 0);

Serial.print("X: ");
Serial.print(x);
Serial.print(" | Y: ");
Serial.print(y);
Serial.print(" | ");

Serial.print("Button: ");
Serial.print(buttonStatus);
Serial.print(" | ");

    Serial.print("From Joystick: ");

    if (buttonPressed) {
  Serial.println("STOP");
  motorStop();
} 
else if (y > 3000) {
  Serial.println("FORWARD");
  motorForward();
} 
else if (y < 1000) {
  Serial.println("BACKWARD");
  motorBackward();
} 
else if (x < 1000) {
  Serial.println("LEFT");
  motorLeft();
} 
else if (x > 3000) {
  Serial.println("RIGHT");
  motorRight();
} 
else {
  Serial.println("STOP");
  motorStop();
}
  }

  // --- CAMERA TOPIC ---
  else if ((topicStr == "robot/direction/camera" || topicStr == "robot/vision") && isAutoMode) {
    const char* aiCommand = doc["vision"];

    Serial.print("From Camera: ");

    if (aiCommand != NULL) {
      String vision = String(aiCommand);

      if (vision == "CENTER") {
        motorForward();
      } 
      else if (vision == "SHARP_LEFT") {
        motorSharpLeft();
      } 
      else if (vision == "LEFT") {
        motorLeft();
      } 
      else if (vision == "SHARP_RIGHT") {
        motorSharpRight();
      } 
      else if (vision == "RIGHT") {
        motorRight();
      } 
      else {
        motorStop();
      }

      Serial.println(vision);
    }
  }
}

// --- SETUP ---
void setup() {
  Serial.begin(115200);
  
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  pinMode(DIR_PIN_A, OUTPUT);
  pinMode(DIR_PIN_B, OUTPUT);

  // Extra L298N setup
  pinMode(L298N_IN1_PIN, OUTPUT);
  pinMode(L298N_IN2_PIN, OUTPUT);
  pinMode(L298N_IN3_PIN, OUTPUT);
  pinMode(L298N_IN4_PIN, OUTPUT);

  // PWM setup for old ESP32 Arduino version
  ledcSetup(PWM_A_CH, freq, resolution);
  ledcSetup(PWM_B_CH, freq, resolution);
  ledcSetup(L298N_ENA_CH, freq, resolution);
  ledcSetup(L298N_ENB_CH, freq, resolution);
  ledcSetup(BUZZER_CH, freq, resolution);

  ledcAttachPin(PWM_PIN_A, PWM_A_CH);
  ledcAttachPin(PWM_PIN_B, PWM_B_CH);
  ledcAttachPin(L298N_ENA_PIN, L298N_ENA_CH);
  ledcAttachPin(L298N_ENB_PIN, L298N_ENB_CH);
  ledcAttachPin(BUZZER_PIN, BUZZER_CH);

  motorStop();

  WiFi.begin(ssid, password);

  Serial.print("Connecting to WiFi");

while (WiFi.status() != WL_CONNECTED) {
  Serial.print(".");
}

Serial.println();
Serial.println("WiFi connected");
Serial.print("IP Address: ");
Serial.println(WiFi.localIP());
  client.setServer(mqtt_server, 1883);
  client.setCallback(callback);
}

// --- MQTT RECONNECT ---
void reconnect() {
  if (!client.connected()) {
    if (client.connect("ESP32_Robot")) {
      client.subscribe("robot/direction/joystick");
      client.subscribe("joystick/data");

      client.subscribe("robot/direction/camera");
      client.subscribe("robot/vision");

      client.subscribe("robot/mode");

      playSuccess();
    }
  }
}

// --- LOOP ---
void loop() {
  if (!client.connected()) {
    static unsigned long lastReconnect = 0;

    if (millis() - lastReconnect > 2000) {
      lastReconnect = millis();
      reconnect();
    }
  }

  client.loop();

  long distance = readUltrasonic();
  long distanceF = distance;
  long distanceR = distance;
  long distanceL = distance;
  delay(500);

  Serial.print("Distance: ");
  Serial.println(distance);

  static unsigned long lastLog = 0;
  static bool avoidingObstacle = false;

  if (millis() - lastLog > 500) {
    lastLog = millis();

    // publish first, so MQTT and InfluxDB always update
    client.publish("home/distanceF", String(distance).c_str());
    client.publish("home/distanceR", String(distance).c_str());
    client.publish("home/distanceL", String(distance).c_str());

    if (distance > 0 && distance < 55) {
      avoidingObstacle = true;
      motorSharpRight();

      Serial.println("Auto-Diverting: Sharp Right");
    }
    else if (avoidingObstacle && (distance >= 55 || distance == 0)) {
      avoidingObstacle = false;
      motorStop();

      Serial.println("Obstacle cleared: Stop");
    }
  }
}
